# TabMind Backend - Environment Configuration Example

# Server Port
PORT=5000

# MongoDB Connection String (e.g., MongoDB Atlas or local)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/tabmind

# JWT Secret for Token Signing
JWT_SECRET=your_super_secret_jwt_key_here

# Groq API Key for AI-powered tab intents
GROQ_API_KEY=your_groq_api_key_here

# Google OAuth Credentials (for Login)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Dashboard Origin (for CORS)
DASHBOARD_URL=http://localhost:3000

# Environment Mode
NODE_ENV=development
